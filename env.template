# ══════════════════════════════════════════════════════════════════════════════
# Cometa Pipeline — Environment Variables Template
#
# Copy this file to .env and fill in the values before running locally.
# In production (Cloud Run), inject all variables via Secret Manager or the
# Cloud Run "Environment variables" panel — never bake secrets into images.
#
# Convention:
#   <REQUIRED>   — service will refuse to start without this variable
#   <OPTIONAL>   — safe default exists; override only when needed
#   <PRODUCTION> — must be set in Cloud Run; leave empty locally
# ══════════════════════════════════════════════════════════════════════════════


# ── Google Cloud Core ─────────────────────────────────────────────────────────

GOOGLE_CLOUD_PROJECT=                       # <REQUIRED> e.g. cometa-mvp
GOOGLE_PROJECT_ID=                          # <REQUIRED> same value as above
GOOGLE_LOCATION=us                          # <OPTIONAL> Document AI region


# ── Credentials — choose ONE of the two strategies below ─────────────────────

# Strategy A: local development — path to downloaded service account JSON key
GOOGLE_APPLICATION_CREDENTIALS=            # e.g. ./cometa_key.json  (never commit the file)

# Strategy B: Cloud Run / CI — full SA JSON injected from Secret Manager
# gcloud secrets create cometa-sa-json --data-file=cometa_key.json
GCP_SERVICE_ACCOUNT_JSON=                  # <PRODUCTION> raw JSON string from Secret Manager


# ── Vertex AI / Gemini ────────────────────────────────────────────────────────

VERTEX_LOCATION=us-central1                # <OPTIONAL>
GEMINI_MODEL=gemini-2.5-flash              # <OPTIONAL> override for cost/speed trade-off


# ── Document AI ───────────────────────────────────────────────────────────────

DOCUMENT_AI_PROCESSOR_ID=                  # <REQUIRED> processor ID from GCP console
DOCUMENT_AI_LOCATION=us                    # <OPTIONAL>


# ── BigQuery ──────────────────────────────────────────────────────────────────

GOOGLE_BIGQUERY_DATASET=BD_Cometa          # <REQUIRED> dataset de producción en proyecto cometa-mvp
BIGQUERY_DATASET=BD_Cometa                 # <REQUIRED> alias legacy — usar GOOGLE_BIGQUERY_DATASET cuando sea posible


# ── Cloud Storage ─────────────────────────────────────────────────────────────

GCS_INPUT_BUCKET=                          # <REQUIRED> legacy alias — preferir GCS_RAW_BUCKET
GCS_OUTPUT_BUCKET=                         # <REQUIRED> legacy alias — preferir GCS_STAGE_BUCKET

# Medallion per-layer buckets (producción)
GCS_RAW_BUCKET=cometa-vc-raw-prod          # <REQUIRED> archivos originales subidos por Founders
GCS_STAGE_BUCKET=cometa-vc-stage-prod      # <REQUIRED> JSON de Gemini y datos intermedios
GCS_GOLD_BUCKET=cometa-vc-gold-prod        # <REQUIRED> contratos certificados 109-KPI
# GCS_GOLD_BUCKET_HISTORICO=historicofund  # bucket de datos históricos del fondo


# ── FastAPI backend ───────────────────────────────────────────────────────────

API_HOST=0.0.0.0                           # <OPTIONAL>
API_PORT=8000                              # <OPTIONAL> Cloud Run overrides with PORT=8080
API_DEBUG=false                            # <OPTIONAL> set true only in development
ENVIRONMENT=production                     # <OPTIONAL> development | staging | production
LOG_LEVEL=INFO                             # <OPTIONAL> DEBUG | INFO | WARNING | ERROR

# Comma-separated list of allowed frontend origins for CORS.
# In production: set to the exact Cloud Run frontend URL(s).
# Locally: leave empty to default to http://localhost:3000.
ALLOWED_ORIGINS=https://cometa-vault-frontend-xxx.run.app  # <REQUIRED in production>

# Set true ONLY in local dev to skip Cloud IAP origin validation.
# Must be false in production — Cloud IAP provides the origin check.
SKIP_ORIGIN_CHECK=false                    # <OPTIONAL>


# ── Auth / JWT ────────────────────────────────────────────────────────────────

# Minimum 32 random characters — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=                                # <REQUIRED>  gcloud secret: cometa-jwt-secret

JWT_SECRET=                                # <REQUIRED> same value as SECRET_KEY (legacy alias)


# ── OAuth — Next.js / NextAuth ────────────────────────────────────────────────

GOOGLE_CLIENT_ID=                          # <REQUIRED> from GCP OAuth 2.0 client
GOOGLE_CLIENT_SECRET=                      # <REQUIRED> gcloud secret: cometa-oauth-secret

NEXTAUTH_URL=https://your-frontend.run.app # <REQUIRED> public URL of the Next.js service
# Minimum 32 random characters — generate with: openssl rand -hex 32
NEXTAUTH_SECRET=                           # <REQUIRED> gcloud secret: cometa-nextauth-secret


# ── Email — Founder confirmation emails (src/services/email_service.py) ───────
#
# Strategy A: Resend (recommended — transactional, no SMTP setup needed)
RESEND_API_KEY=                            # <OPTIONAL> from resend.com dashboard
#
# Strategy B: SMTP (any provider — Gmail, SendGrid relay, Mailgun, etc.)
SMTP_HOST=                                 # <OPTIONAL> e.g. smtp.sendgrid.net
SMTP_PORT=587                              # <OPTIONAL> 587 (STARTTLS) or 465 (SSL)
SMTP_USER=                                 # <OPTIONAL> SMTP username / API key
SMTP_PASSWORD=                             # <OPTIONAL> SMTP password / API key
#
# Sender identity (shown in email From: header)
EMAIL_FROM=no-reply@cometa.vc              # <OPTIONAL> verified sender address
EMAIL_FROM_NAME=Cometa Vault               # <OPTIONAL>
#
# If none of the above are set, emails are printed to stdout (dev mode).


# ── Frontend (Next.js) ────────────────────────────────────────────────────────

# Public URL of the FastAPI backend — embedded at build time in the Next.js bundle
NEXT_PUBLIC_API_URL=https://cometa-api.run.app  # <REQUIRED> set as Cloud Run --build-arg

# Google OAuth Client ID for analyst sign-in (GIS button on /login).
# Must match the GOOGLE_CLIENT_ID value above.
# In Cloud Run, pass as --build-arg NEXT_PUBLIC_GOOGLE_CLIENT_ID=<value>
NEXT_PUBLIC_GOOGLE_CLIENT_ID=                   # <REQUIRED for Google Sign-In>

# Looker Studio dashboard URL injected into FinalizeAnalysisResponse.dashboard_url
# so the "Ver Datos en Looker Studio" button opens the correct report after finalization.
DASHBOARD_URL=https://datastudio.google.com/reporting/99155726-349c-440c-81eb-9a199120b5f6
