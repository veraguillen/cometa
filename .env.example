# Google Cloud Configuration
GOOGLE_APPLICATION_CREDENTIALS=cometa_key.json
GOOGLE_PROJECT_ID=cometa-mvp
GOOGLE_LOCATION=us

# BigQuery — dataset destino
# Producción: BD_Cometa   |   Desarrollo: BD_Cometa_Dev
BIGQUERY_DATASET=BD_Cometa_Dev

# Document AI Configuration
DOCUMENT_AI_PROCESSOR_ID=c5e1adfde68e63cf
DOCUMENT_AI_LOCATION=us

# Gemini/Vertex AI Configuration
VERTEX_AI_LOCATION=us
GEMINI_MODEL=gemini-2.5-flash

# Google Cloud Storage Configuration
GCS_INPUT_BUCKET=cometa-vc-raw-prod
GCS_OUTPUT_BUCKET=cometa-vc-stage-prod
GCS_RAW_BUCKET=cometa-vc-raw-prod
GCS_STAGE_BUCKET=cometa-vc-stage-prod
GCS_GOLD_BUCKET=cometa-vc-gold-prod

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Google OAuth — Analyst sign-in (@cometa.vc only)
GOOGLE_CLIENT_ID=92572839783-7ot0oqfemmbah7mubirkee631fl7h8lm.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...  # from GCP OAuth 2.0 client (keep secret)
JWT_SECRET=cometa-dev-secret-change-in-prod

# Next.js public vars (embedded at build time)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=92572839783-7ot0oqfemmbah7mubirkee631fl7h8lm.apps.googleusercontent.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Security (para producción)
SECRET_KEY=tu-secret-key-aqui-para-produccion
CORS_ORIGINS=["http://localhost:3000", "https://tu-dominio.com"]

# Email Configuration (para notificaciones opcionales)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password

# Monitoring (opcional)
SENTRY_DSN=tu-sentry-dsn-aqui
LOG_LEVEL=INFO

# Development/Production
ENVIRONMENT=development

# Nota: Asegúrate de que estos buckets existan en tu proyecto de GCP
# y que la cuenta de servicio tenga los permisos necesarios.
